{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>homelab/renovate-config",
    "local>homelab/kops//.renovate/groups.json5",
    "local>homelab/kops//.renovate/labels.json5",
    "local>homelab/kops//.renovate/renovateMerge.json5"
  ],
  "baseBranchPatterns": ["main"],
  "assignAutomerge": true,
  "assignees": ["@sujiba-bot"],
  "reviewers": ["@sujiba"],
  "flux": {
    "managerFilePatterns": ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"]
  }
}
